  "components": {
    "schemas": {
      "UserRoleAssignReq": {
        "required": [
          "roleIds"
        ],
        "type": "object",
        "properties": {
          "roleIds": {
            "type": "array",
            "description": "角色ID列表",
            "example": [
              1,
              2
            ],
            "items": {
              "type": "integer",
              "description": "角色ID列表",
              "format": "int64"
            }
          }
        },
        "description": "用户角色分配请求"
      },
      "ResultVoid": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object"
          }
        }
      },
      "SlaConfigUpdateReq": {
        "required": [
          "acceptMinutes",
          "finishMinutes",
          "priority",
          "type"
        ],
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "工单类型",
            "example": "REPAIR"
          },
          "priority": {
            "type": "integer",
            "description": "优先级: 0普通 1紧急",
            "format": "int32",
            "example": 0
          },
          "acceptMinutes": {
            "type": "integer",
            "description": "接单时限（分钟）",
            "format": "int32",
            "example": 30
          },
          "finishMinutes": {
            "type": "integer",
            "description": "完成时限（分钟）",
            "format": "int32",
            "example": 120
          }
        },
        "description": "SLA配置更新请求"
      },
      "RoleUpdateReq": {
        "required": [
          "roleName"
        ],
        "type": "object",
        "properties": {
          "roleName": {
            "type": "string",
            "description": "角色名称",
            "example": "更新后的角色名"
          },
          "remark": {
            "type": "string",
            "description": "备注"
          }
        },
        "description": "角色更新请求"
      },
      "ResultRole": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/Role"
          }
        }
      },
      "Role": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "roleCode": {
            "type": "string"
          },
          "roleName": {
            "type": "string"
          },
          "remark": {
            "type": "string"
          }
        }
      },
      "RolePermissionAssignReq": {
        "required": [
          "permIds"
        ],
        "type": "object",
        "properties": {
          "permIds": {
            "type": "array",
            "description": "权限ID列表",
            "example": [
              1,
              2,
              3
            ],
            "items": {
              "type": "integer",
              "description": "权限ID列表",
              "format": "int64"
            }
          }
        },
        "description": "角色权限分配请求"
      },
      "RegisterReq": {
        "required": [
          "password",
          "username"
        ],
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "description": "用户名",
            "example": "zhangsan"
          },
          "password": {
            "type": "string",
            "description": "密码",
            "example": "123456"
          },
          "phone": {
